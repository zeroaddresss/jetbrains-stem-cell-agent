# Choose one provider profile below.
# Model can be overridden by CLI: --model <model_name>
OPENAI_MODEL=deepseek/deepseek-v4-pro

# --- Profile A: OpenRouter (recommended for reproducing our reported runs) ---
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenRouter metadata headers
# OPENROUTER_HTTP_REFERER=https://your-project-url.example
# OPENROUTER_X_TITLE=evolving-stem-agent

# --- Profile B: OpenAI API key only ---
# Set OPENAI_API_KEY and leave OPENAI_BASE_URL unset/commented.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
